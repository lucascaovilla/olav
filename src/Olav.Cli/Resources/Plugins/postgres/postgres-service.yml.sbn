  postgres:
    image: postgres:16
    restart: always
    env_file: ../.env
    environment:
      POSTGRES_DB: {{ projectNameLower }}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 10

volumes:
  postgres_data:
