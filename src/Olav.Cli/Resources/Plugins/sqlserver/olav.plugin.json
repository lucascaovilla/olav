{
  "id": "sqlserver",
  "version": "0.1.0",
  "displayName": "SQL Server via EF Core",
  "description": "Scaffolds a SQL Server persistence layer with EF Core.",
  "author": "olav-official",
  "category": "infrastructure",
  "delivery": "package",
  "compatibility": { "olavMinVersion": "0.1.0" },
  "nugetPackage": { "id": "Olav.Infrastructure.SqlServer", "version": "0.1.0" },
  "persistenceProjectSuffix": "Persistence.SqlServer",
  "generates": [
    {
      "template": "sqlserver-di.cs.sbn",
      "output": "src/{{namespace}}.Infrastructure/Persistence/SqlServer/DependencyInjection.cs"
    }
  ],
  "parameters": [
    { "name": "connectionStringName", "type": "string", "default": "DefaultConnection" }
  ],
  "conflicts": ["postgres"],
  "requires": []
}
